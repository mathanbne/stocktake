# ---------------------------------------------------------------------------
# CLIENT (VITE_*) — inlined into public JavaScript by Vite at build time.
# Never put a secret here. Tuning knobs only.
# ---------------------------------------------------------------------------
VITE_SYNC_INTERVAL_MS=30000
VITE_SYNC_BATCH_SIZE=50
VITE_SCAN_COOLDOWN_MS=2500

# ---------------------------------------------------------------------------
# SERVER — read only by the Vercel functions in api/. Set these in the Vercel
# dashboard (Project → Settings → Environment Variables), not in a committed file.
# ---------------------------------------------------------------------------

# Shared code each device types once on the Start screen to be allowed to sync.
STOCKTAKE_ACCESS_CODE=change-me

# Entra app registration (app-only / client credentials — no user signs in).
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Which workbook. App-only tokens have no /me, so the drive is named explicitly.
# See "Finding the two ids" in README.md.
EXCEL_DRIVE_ID=
EXCEL_ITEM_ID=
