# All configuration is client-side now — there is no server and no secret.
# Copy to .env for local dev; set the same values in Vercel for deploys.

# Entra application (client) id from your SPA app registration.
# Public by design: a public client holds no secret and proves itself with PKCE,
# so this identifies the app rather than authorising it.
VITE_MS_CLIENT_ID=

# Optional. Blank accepts any work/school account. Set your tenant id (a GUID)
# to restrict sign-in to your own organisation.
VITE_MS_TENANT_ID=

# Sync cadence and batching — tune without touching code.
VITE_SYNC_INTERVAL_MS=30000
VITE_SYNC_BATCH_SIZE=50

# Same-tag re-detection suppression while it stays in frame.
VITE_SCAN_COOLDOWN_MS=2500
