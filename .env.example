# ---------------------------------------------------------------------------
# CLIENT (VITE_*) — inlined into public JavaScript by Vite at build time.
# Never put a secret here. Tuning knobs only.
# ---------------------------------------------------------------------------
VITE_SYNC_INTERVAL_MS=30000
VITE_SYNC_BATCH_SIZE=50
VITE_SCAN_COOLDOWN_MS=2500

# ---------------------------------------------------------------------------
# SERVER — read only by the Vercel functions in api/. Set these in the Vercel
# dashboard (Project → Settings → Environment Variables), not in a committed file.
# ---------------------------------------------------------------------------

# Shared code each device types once on the Start screen to be allowed to sync.
# Also gates /api/auth/start, so keep it non-obvious.
STOCKTAKE_ACCESS_CODE=change-me

# Entra app registration (delegated — the app acts as whoever signs in).
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Optional. Leave blank to accept any work/school account ("organizations").
# Set your tenant id to restrict sign-in to your own organisation.
MS_TENANT_ID=

# Which workbook. Leave EXCEL_DRIVE_ID blank for your own OneDrive for Business;
# set it when the file lives in a SharePoint / Teams library.
# See "Finding the ids" in README.md.
EXCEL_DRIVE_ID=
EXCEL_ITEM_ID=

# Where the refresh token is kept. Entra rotates it on every use, so it cannot
# live in an env var — env vars aren't writable at runtime. Provision Upstash
# Redis from the Vercel Marketplace and these two are injected automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=
