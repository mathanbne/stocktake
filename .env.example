# ---------------------------------------------------------------------------
# CLIENT (VITE_*) — inlined into public JavaScript by Vite at build time.
# Never put a secret here. Tuning knobs only.
# ---------------------------------------------------------------------------
VITE_SYNC_INTERVAL_MS=30000
VITE_SYNC_BATCH_SIZE=50
VITE_SCAN_COOLDOWN_MS=2500

# ---------------------------------------------------------------------------
# SERVER — read only by the Vercel functions in api/. Set these in the Vercel
# dashboard (Project → Settings → Environment Variables), not in a committed file.
# ---------------------------------------------------------------------------

# Shared code each device types once on the Start screen to be allowed to sync.
STOCKTAKE_ACCESS_CODE=change-me

# Entra app registration
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Which workbook. EXCEL_ITEM_ID is the driveItem id of stock.xlsx.
EXCEL_ITEM_ID=
# Required only in app-only (work M365) mode — there is no /me to resolve.
EXCEL_DRIVE_ID=

# --- Pick ONE auth mode ---
#
# A) Work / school M365: set the tenant id to use app-only (client credentials).
#    Needs Files.ReadWrite.All *application* permission + admin consent.
#    Nothing else below is required.
MS_TENANT_ID=
#
# B) Personal OneDrive (outlook.com): leave MS_TENANT_ID empty. The server uses a
#    delegated refresh token instead. MSA rotates that token on every use, so it
#    cannot live in an env var — it is kept in KV and rewritten on each refresh.
#    Provision Upstash Redis from the Vercel Marketplace, then run the one-time
#    consent at /api/auth/start?code=<STOCKTAKE_ACCESS_CODE>
KV_REST_API_URL=
KV_REST_API_TOKEN=
